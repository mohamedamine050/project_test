GLUE_DATABASE=aws_glue_catalog_database.main.name
GLUE_CRAWLER=aws_glue_crawler.main.name

# ==================================================
# EMR (SPARK CLUSTER)
# ==================================================
EMR_CLUSTER_ID=aws_emr_cluster.data_cluster.id
EMR_CLUSTER_NAME=aws_emr_cluster.data_cluster.name
EMR_MASTER_INSTANCE=aws_emr_cluster.data_cluster.master_instance_type
EMR_WORKER_INSTANCE=aws_emr_cluster.data_cluster.core_instance_type
EMR_LOG_URI=aws_emr_cluster.data_cluster.log_uri

# ==================================================
# RDS DATABASES
# ==================================================
RDS_POSTGRES_HOST=aws_db_instance.postgres.endpoint
RDS_POSTGRES_PORT=aws_db_instance.postgres.port
RDS_POSTGRES_DB=aws_db_instance.postgres.db_name

RDS_MYSQL_HOST=aws_db_instance.mysql.endpoint
RDS_MYSQL_PORT=aws_db_instance.mysql.port
RDS_MYSQL_DB=aws_db_instance.mysql.db_name

# ==================================================
# AWS LAMBDA
# ==================================================
LAMBDA_INGESTION=aws_lambda_function.ingestion.function_name
LAMBDA_EVENT_PROCESSOR=aws_lambda_function.event_processor.function_name
SQS_QUEUE_INGESTION=aws_sqs_queue.ingestion.id
SNS_TOPIC_ALERTS=aws_sns_topic.alerts.arn
CW_LOG_GROUP_GLUE=aws_cloudwatch_log_group.glue.name
CW_LOG_GROUP_LAMBDA=aws_cloudwatch_log_group.lambda.name
CW_LOG_GROUP_EMR=aws_cloudwatch_log_group.emr.name

CW_METRIC_NAMESPACE=DataPlatform/Prod

# ==================================================
# IAM ROLES
