# ==================================================
# S3 DATA LAKE
# ==================================================
S3_DATA_LAKE_BUCKET=aws_s3_bucket.data_lake.bucket
S3_LOGS_BUCKET=aws_s3_bucket.logs.bucket
S3_ARTIFACTS_BUCKET=aws_s3_bucket.artifacts.bucket

S3_BRONZE_PREFIX=bronze/
S3_SILVER_PREFIX=silver/
S3_GOLD_PREFIX=gold/

# ==================================================
# AWS GLUE (ETL JOBS)
# ==================================================
GLUE_JOB_BRONZE_TO_SILVER=aws_glue_job.bronze_to_silver.name
GLUE_JOB_SILVER_TO_GOLD=aws_glue_job.silver_to_gold.name
